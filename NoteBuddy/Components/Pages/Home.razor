@page "/"
@using NoteBuddy.Models
@using NoteBuddy.Services
@inject CorkboardService CorkboardService
@inject IDialogService DialogService
@inject IWebHostEnvironment Environment
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>NoteBuddy - Virtual Corkboard</PageTitle>

<!-- Site Header: logo + filter -->
<div class="site-header">
    <img src="images/note-buddy-logo.png" alt="NoteBuddy" class="corkboard-logo" />
    <MudTextField Value="_filterText"
                  ValueChanged="OnFilterChanged"
                  Placeholder="Filter notes..."
                  Variant="Variant.Outlined"
                  Adornment="Adornment.End"
                  AdornmentIcon="@(_filterText?.Length > 0 ? Icons.Material.Filled.Close : Icons.Material.Filled.Search)"
                  OnAdornmentClick="OnFilterAdornmentClick"
                  Immediate="true"
                  Class="filter-field"
                  Margin="Margin.Dense"
                  T="string" />
</div>

<!-- Tab Row + Toolbar -->
<div class="tab-area">
    <TabBar Tabs="FilteredTabs"
            SelectedTabId="_selectedTabId"
            OnTabSelected="SelectTab"
            OnTabAdded="OnTabAdded"
            OnTabUpdated="OnTabUpdated"
            OnTabDeleted="OnTabDeleted"
            OnTabReordered="OnTabReordered" />
    <div class="corkboard-toolbar">
        <MudButton Class="btn-add-note"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.NoteAdd"
                   OnClick="AddNewNote">
            Add New Note
        </MudButton>
        <MudButton Class="btn-add-picture"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.AddPhotoAlternate"
                   OnClick="AddNewPicture">
            Add Picture
        </MudButton>
        <MudButton Class="btn-organize"
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.GridView"
                   OnClick="OrganizeBoard">
            Organize
        </MudButton>
    </div>
</div>

<!-- Corkboard Content -->
<div class="corkboard" style="border: 3px solid @GetSelectedTabColor();" @ondblclick="OnCorkboardDoubleClick">

    @foreach (var picture in _pictures)
    {
        @if (!IsFilterActive)
        {
            <PinnedPictureCard @key="picture.Id"
                               Picture="picture"
                               OnDelete="DeletePicture"
                               OnMoved="OnPictureMoved"
                               OnZOrderChanged="OnZOrderChanged"
                               AvailableTabs="OtherTabs"
                               OnMoveToTab="MovePictureToTab" />
        }
    }

    @{ var filteredNotes = FilteredNotes.ToList(); }
    @{ var filterPositions = IsFilterActive ? ComputeFilterLayout(filteredNotes) : null; }
    @foreach (var note in filteredNotes)
    {
        <StickyNoteCard @key="note.Id"
                        Note="note"
                        OnEdit="EditNote"
                        OnDelete="DeleteNote"
                        OnMoved="OnNoteMoved"
                        OnItemToggled="OnNoteItemToggled"
                        OnResized="OnNoteResized"
                        OnZOrderChanged="OnZOrderChanged"
                        DisplayX="@(filterPositions?.GetValueOrDefault(note.Id).X)"
                        DisplayY="@(filterPositions?.GetValueOrDefault(note.Id).Y)"
                        AvailableTabs="OtherTabs"
                        OnMoveToTab="MoveNoteToTab" />
    }
</div>

@if (_activeReminder != null)
{
    <div class="reminder-overlay" @onclick="DismissReminder">
        <div class="reminder-card" @onclick:stopPropagation="true">
            <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Class="reminder-icon" />
            <div class="reminder-title">@_activeReminder.Title</div>
            <div class="reminder-due">Due: @_activeReminder.DueDate!.Value.ToString("M/d/yyyy h:mm tt")</div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DismissReminder">Dismiss</MudButton>
        </div>
    </div>
}

@code {
    // ===== Tab state =====
    private List<Tab> _tabs = new();
    private Guid _selectedTabId;

    // ===== Active tab's notes/pictures =====
    private List<StickyNote> _notes = new();
    private List<PinnedPicture> _pictures = new();

    private string? _filterText;
    private StickyNote? _activeReminder;
    private Timer? _reminderTimer;
    private DotNetObjectReference<Home>? _pageRef;
    private (double X, double Y)? _pendingClickPosition;

    private bool IsFilterActive => !string.IsNullOrWhiteSpace(_filterText);

    /// <summary>Tabs filtered by the active filter text (matches tab title or child note content).</summary>
    private List<Tab> FilteredTabs => IsFilterActive
        ? _tabs.Where(t =>
            t.Title.Contains(_filterText!, StringComparison.OrdinalIgnoreCase) ||
            t.Notes.Any(n =>
                n.Title.Contains(_filterText!, StringComparison.OrdinalIgnoreCase) ||
                n.Items.Any(i => i.Text.Contains(_filterText!, StringComparison.OrdinalIgnoreCase))))
          .ToList()
        : _tabs;

    /// <summary>Notes on the active tab matching the current filter.</summary>
    private IEnumerable<StickyNote> FilteredNotes => IsFilterActive
        ? _notes.Where(n =>
            n.Title.Contains(_filterText!, StringComparison.OrdinalIgnoreCase) ||
            n.Items.Any(i => i.Text.Contains(_filterText!, StringComparison.OrdinalIgnoreCase)))
        : _notes;

    /// <summary>List of tabs other than the currently selected one (for "Move to" menus).</summary>
    private List<Tab> OtherTabs => _tabs.Where(t => t.Id != _selectedTabId).OrderBy(t => t.SortOrder).ToList();

    private static readonly Dictionary<string, string> TabColors = new()
    {
        ["yellow"] = "#b8960a",
        ["blue"] = "#5a9aaa",
        ["green"] = "#2d8a2d",
        ["orange"] = "#c07a5a",
        ["pink"] = "#c060a0",
        ["purple"] = "#7a3d9a"
    };

    private string GetSelectedTabColor()
    {
        var tab = _tabs.FirstOrDefault(t => t.Id == _selectedTabId);
        return tab != null ? TabColors.GetValueOrDefault(tab.Color, "#a08060") : "#a08060";
    }

    private void OnFilterChanged(string value)
    {
        _filterText = value;
        EnsureSelectedTabVisible();
        RefreshActiveTabContent();
    }

    private void OnFilterAdornmentClick()
    {
        if (IsFilterActive)
        {
            _filterText = string.Empty;
            EnsureSelectedTabVisible();
            RefreshActiveTabContent();
        }
    }

    /// <summary>If the selected tab is hidden by the filter, select the first visible tab.</summary>
    private void EnsureSelectedTabVisible()
    {
        var visible = FilteredTabs;
        if (visible.All(t => t.Id != _selectedTabId) && visible.Any())
        {
            _selectedTabId = visible.First().Id;
        }
    }

    private Dictionary<Guid, (double X, double Y)> ComputeFilterLayout(List<StickyNote> notes)
    {
        const double startX = 20;
        const double startY = 14;
        const double gap = 20;
        const double baseWidth = 325.0;
        const double baseHeight = 324.0;
        const double maxRowWidth = 1700;

        var positions = new Dictionary<Guid, (double X, double Y)>();
        double curX = startX;
        double curY = startY;
        double rowHeight = 0;

        foreach (var note in notes)
        {
            double w = baseWidth * note.Scale;
            double h = baseHeight * note.Scale;

            if (curX + w > maxRowWidth && curX > startX)
            {
                curX = startX;
                curY += rowHeight + gap;
                rowHeight = 0;
            }

            positions[note.Id] = (curX, curY);
            curX += w + gap;
            rowHeight = Math.Max(rowHeight, h);
        }

        return positions;
    }

    // ===== Lifecycle =====

    protected override void OnInitialized()
    {
        _tabs = CorkboardService.GetTabs();
        if (_tabs.Any())
        {
            _selectedTabId = _tabs.First().Id;
            RefreshActiveTabContent();
        }
        _reminderTimer = new Timer(CheckReminders, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(30));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _pageRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("corkboardInterop.registerPageEvents", _pageRef);
        }
    }

    /// <summary>Refreshes _notes and _pictures from the currently selected tab.</summary>
    private void RefreshActiveTabContent()
    {
        _notes = CorkboardService.GetNotes(_selectedTabId);
        _pictures = CorkboardService.GetPictures(_selectedTabId);
    }

    // ===== Tab management =====

    private void SelectTab(Guid tabId)
    {
        _selectedTabId = tabId;
        RefreshActiveTabContent();
        StateHasChanged();
    }

    private async Task OnTabAdded(Tab tab)
    {
        await CorkboardService.AddTabAsync(tab);
        _tabs = CorkboardService.GetTabs();
        _selectedTabId = tab.Id;
        RefreshActiveTabContent();
        StateHasChanged();
    }

    private async Task OnTabUpdated(Tab tab)
    {
        await CorkboardService.UpdateTabAsync(tab);
        _tabs = CorkboardService.GetTabs();
        StateHasChanged();
    }

    private async Task OnTabDeleted(Guid tabId)
    {
        await CorkboardService.DeleteTabAsync(tabId);
        _tabs = CorkboardService.GetTabs();
        if (_selectedTabId == tabId)
        {
            _selectedTabId = _tabs.FirstOrDefault()?.Id ?? Guid.Empty;
        }
        RefreshActiveTabContent();
        StateHasChanged();
    }

    private async Task OnTabReordered((Guid draggedId, Guid targetId) args)
    {
        var ordered = _tabs.OrderBy(t => t.SortOrder).ToList();
        var draggedTab = ordered.FirstOrDefault(t => t.Id == args.draggedId);
        var targetTab = ordered.FirstOrDefault(t => t.Id == args.targetId);
        if (draggedTab == null || targetTab == null) return;

        ordered.Remove(draggedTab);
        var targetIndex = ordered.IndexOf(targetTab);
        ordered.Insert(targetIndex, draggedTab);

        await CorkboardService.ReorderTabsAsync(ordered.Select(t => t.Id).ToList());
        _tabs = CorkboardService.GetTabs();
        StateHasChanged();
    }

    // ===== Move between tabs =====

    private async Task MoveNoteToTab((Guid NoteId, Guid TabId) args)
    {
        await CorkboardService.MoveNoteToTabAsync(args.NoteId, args.TabId);
        RefreshActiveTabContent();
        StateHasChanged();
    }

    private async Task MovePictureToTab((Guid PictureId, Guid TabId) args)
    {
        await CorkboardService.MovePictureToTabAsync(args.PictureId, args.TabId);
        RefreshActiveTabContent();
        StateHasChanged();
    }

    // ===== Note CRUD =====

    private async Task AddNewNote()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<StickyNoteDialog>("New Sticky Note", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: StickyNote newNote })
        {
            if (_pendingClickPosition.HasValue)
            {
                newNote.PositionX = _pendingClickPosition.Value.X;
                newNote.PositionY = Math.Max(14, _pendingClickPosition.Value.Y);
                _pendingClickPosition = null;
            }
            else
            {
                newNote.PositionX = GetNextPositionX(_notes.Count);
                newNote.PositionY = GetNextPositionY(_notes.Count);
            }
            await CorkboardService.AddNoteAsync(_selectedTabId, newNote);
            RefreshActiveTabContent();
            StateHasChanged();
        }
        else
        {
            _pendingClickPosition = null;
        }
    }

    private async Task EditNote(StickyNote note)
    {
        var parameters = new DialogParameters<StickyNoteDialog>
        {
            { x => x.ExistingNote, note }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<StickyNoteDialog>("Edit Sticky Note", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            if (result.Data is StickyNote updatedNote)
            {
                await CorkboardService.UpdateNoteAsync(updatedNote);
            }
            else
            {
                await CorkboardService.DeleteNoteAsync(note.Id);
            }
            RefreshActiveTabContent();
            StateHasChanged();
        }
    }

    private async Task DeleteNote(Guid noteId)
    {
        await CorkboardService.DeleteNoteAsync(noteId);
        RefreshActiveTabContent();
        StateHasChanged();
    }

    private async Task OnNoteMoved((Guid Id, double X, double Y) position)
    {
        await CorkboardService.UpdateNotePositionAsync(position.Id, position.X, position.Y);
    }

    private async Task OnNoteResized((Guid Id, double Scale) resize)
    {
        var note = _notes.FirstOrDefault(n => n.Id == resize.Id);
        if (note != null)
        {
            note.Scale = resize.Scale;
            await CorkboardService.UpdateNoteAsync(note);
        }
    }

    private async Task OnNoteItemToggled(StickyNote note)
    {
        await CorkboardService.UpdateNoteAsync(note);
    }

    // ===== Z-order =====

    private async Task OnZOrderChanged((Guid Id, ZOrderAction Action) args)
    {
        var allZIndexes = _notes.Select(n => n.ZIndex)
            .Concat(_pictures.Select(p => p.ZIndex))
            .ToList();

        if (allZIndexes.Count == 0) return;

        var note = _notes.FirstOrDefault(n => n.Id == args.Id);
        var picture = note == null ? _pictures.FirstOrDefault(p => p.Id == args.Id) : null;
        if (note == null && picture == null) return;

        int currentZ = note?.ZIndex ?? picture!.ZIndex;
        int newZ = currentZ;

        switch (args.Action)
        {
            case ZOrderAction.BringToFront:
                newZ = allZIndexes.Max() + 1;
                break;
            case ZOrderAction.SendToBack:
                newZ = allZIndexes.Min() - 1;
                break;
            case ZOrderAction.BringForward:
                newZ = currentZ + 1;
                break;
            case ZOrderAction.SendBackward:
                newZ = currentZ - 1;
                break;
        }

        if (note != null)
        {
            note.ZIndex = newZ;
            await CorkboardService.UpdateNoteAsync(note);
        }
        else
        {
            picture!.ZIndex = newZ;
            await CorkboardService.UpdatePictureAsync(picture);
        }

        StateHasChanged();
    }

    // ===== Picture CRUD =====

    private async Task AddNewPicture()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<PictureDialog>("Add Picture", options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: IBrowserFile file })
        {
            var extension = Path.GetExtension(file.Name);
            var fileName = $"{Guid.NewGuid()}{extension}";
            var filePath = Path.Combine(CorkboardService.GetUploadsPath(), fileName);

            await using (var stream = file.OpenReadStream(10 * 1024 * 1024))
            {
                await using (var fileStream = File.Create(filePath))
                {
                    await stream.CopyToAsync(fileStream);
                }
            }

            var picture = new PinnedPicture
            {
                FileName = fileName,
                PositionX = GetNextPositionX(_notes.Count + _pictures.Count),
                PositionY = GetNextPositionY(_notes.Count + _pictures.Count)
            };

            await CorkboardService.AddPictureAsync(_selectedTabId, picture);
            RefreshActiveTabContent();
            StateHasChanged();
        }
    }

    private async Task DeletePicture(Guid pictureId)
    {
        await CorkboardService.DeletePictureAsync(pictureId);
        RefreshActiveTabContent();
        StateHasChanged();
    }

    private async Task OnPictureMoved((Guid Id, double X, double Y) position)
    {
        await CorkboardService.UpdatePicturePositionAsync(position.Id, position.X, position.Y);
    }

    // ===== Organize =====

    private async Task OrganizeBoard()
    {
        const double startX = 20;
        const double startY = 14;
        const double gap = 20;
        const double baseNoteWidth = 325;
        const double baseNoteHeight = 324;
        const double pictureWidth = 220;
        const double pictureHeight = 220;
        const double maxRowWidth = 1700;

        var items = new List<(Guid Id, double Width, double Height, bool IsNote)>();

        foreach (var note in _notes.OrderBy(n => n.Title, StringComparer.OrdinalIgnoreCase))
        {
            items.Add((note.Id, baseNoteWidth * note.Scale, baseNoteHeight * note.Scale, true));
        }
        foreach (var pic in _pictures)
        {
            items.Add((pic.Id, pictureWidth, pictureHeight, false));
        }

        double curX = startX;
        double curY = startY;
        double rowHeight = 0;

        foreach (var item in items)
        {
            if (curX + item.Width > maxRowWidth && curX > startX)
            {
                curX = startX;
                curY += rowHeight + gap;
                rowHeight = 0;
            }

            if (item.IsNote)
            {
                var note = _notes.First(n => n.Id == item.Id);
                note.PositionX = curX;
                note.PositionY = curY;
                await CorkboardService.UpdateNotePositionAsync(note.Id, curX, curY);
            }
            else
            {
                var pic = _pictures.First(p => p.Id == item.Id);
                pic.PositionX = curX;
                pic.PositionY = curY;
                await CorkboardService.UpdatePicturePositionAsync(pic.Id, curX, curY);
            }

            curX += item.Width + gap;
            rowHeight = Math.Max(rowHeight, item.Height);
        }

        StateHasChanged();
    }

    // ===== Position helpers =====

    private double GetNextPositionX(int index)
    {
        int col = index % 5;
        int row = index / 5;
        return 20 + col * 345 + (row % 2) * 20;
    }

    private double GetNextPositionY(int index)
    {
        int row = index / 5;
        return 14 + row * 345;
    }

    // ===== Reminders =====

    private void CheckReminders(object? state)
    {
        if (_activeReminder != null) return;

        var now = DateTime.Now;
        var allNotes = CorkboardService.GetAllNotes();

        foreach (var note in allNotes)
        {
            if (!note.DueDate.HasValue || !note.ReminderMinutesBefore.HasValue)
                continue;

            if (note.ReminderDismissed)
                continue;

            var reminderStart = note.DueDate.Value.AddMinutes(-note.ReminderMinutesBefore.Value);

            if (now >= reminderStart && now <= note.DueDate.Value)
            {
                _activeReminder = note;
                InvokeAsync(StateHasChanged);
                break;
            }
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task DismissReminder()
    {
        if (_activeReminder == null) return;

        _activeReminder.ReminderDismissed = true;
        _activeReminder.ReminderDismissedAt = DateTime.UtcNow;
        await CorkboardService.UpdateNoteAsync(_activeReminder);
        _activeReminder = null;
        StateHasChanged();
    }

    // ===== Quick-add (double-click, keyboard, drag-drop) =====

    private async Task OnCorkboardDoubleClick(MouseEventArgs e)
    {
        var pos = await JS.InvokeAsync<ClickPosition?>(
            "corkboardInterop.getCorkboardClickPosition", e.ClientX, e.ClientY);

        if (pos == null) return;

        _pendingClickPosition = (pos.X, pos.Y);
        await AddNewNote();
    }

    [JSInvokable]
    public async Task OnKeyboardNewNote()
    {
        _pendingClickPosition = null;
        await AddNewNote();
    }

    [JSInvokable]
    public async Task OnImageDropped(string base64Data, string extension, double x, double y)
    {
        var fileName = $"{Guid.NewGuid()}{extension}";
        var filePath = Path.Combine(CorkboardService.GetUploadsPath(), fileName);

        var bytes = Convert.FromBase64String(base64Data);
        await File.WriteAllBytesAsync(filePath, bytes);

        var picture = new PinnedPicture
        {
            FileName = fileName,
            PositionX = x,
            PositionY = Math.Max(14, y)
        };

        await CorkboardService.AddPictureAsync(_selectedTabId, picture);
        RefreshActiveTabContent();
        await InvokeAsync(StateHasChanged);
    }

    private class ClickPosition
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    // ===== Dispose =====

    public async void Dispose()
    {
        _reminderTimer?.Dispose();
        _pageRef?.Dispose();
        try
        {
            await JS.InvokeVoidAsync("corkboardInterop.unregisterPageEvents");
        }
        catch
        {
            // JS interop may fail during circuit disposal
        }
    }
}