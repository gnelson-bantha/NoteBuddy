@using NoteBuddy.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Picture</MudText>
    </TitleContent>
    <DialogContent>
        <MudFileUpload T="IBrowserFile"
                       Accept=".jpg,.jpeg,.png,.gif,.webp"
                       MaximumFileCount="1"
                       FilesChanged="OnFileSelected">
            <CustomContent>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Image"
                           OnClick="@context.OpenFilePickerAsync">
                    Choose Image
                </MudButton>
            </CustomContent>
        </MudFileUpload>

        @if (!string.IsNullOrEmpty(PreviewUrl))
        {
            <div class="mt-3 d-flex justify-center">
                <img src="@PreviewUrl"
                     alt="Preview"
                     style="max-width: 300px; max-height: 300px; object-fit: contain; border: 1px solid #ddd; border-radius: 4px;" />
            </div>
            <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-1">@FileName</MudText>
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@ErrorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save"
                   Disabled="@(SelectedFile == null)">
            Add to Board
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>The MudBlazor dialog instance provided via cascading parameter.</summary>
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>The image file selected by the user.</summary>
    private IBrowserFile? SelectedFile { get; set; }

    /// <summary>Base64 data URL used for the image preview.</summary>
    private string? PreviewUrl { get; set; }

    /// <summary>Display name of the selected file.</summary>
    private string? FileName { get; set; }

    /// <summary>Error message shown when file validation fails.</summary>
    private string? ErrorMessage { get; set; }

    /// <summary>Maximum allowed file size in bytes (10 MB).</summary>
    private const long MaxFileSize = 10 * 1024 * 1024; // 10MB

    /// <summary>Handles file selection, validates size, and generates a base64 preview.</summary>
    private async Task OnFileSelected(IBrowserFile file)
    {
        ErrorMessage = null;

        if (file.Size > MaxFileSize)
        {
            ErrorMessage = "File size must be under 10MB.";
            SelectedFile = null;
            PreviewUrl = null;
            return;
        }

        SelectedFile = file;
        FileName = file.Name;

        // Read the file into memory and convert to a base64 data URL for preview
        var buffer = new byte[file.Size];
        await using var stream = file.OpenReadStream(MaxFileSize);
        var bytesRead = await stream.ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer, 0, bytesRead);
        PreviewUrl = $"data:{file.ContentType};base64,{base64}";

        StateHasChanged();
    }

    /// <summary>Closes the dialog and returns the selected file to the caller.</summary>
    private void Save()
    {
        if (SelectedFile != null)
        {
            MudDialog.Close(DialogResult.Ok(SelectedFile));
        }
    }

    /// <summary>Cancels the dialog without selecting a file.</summary>
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
