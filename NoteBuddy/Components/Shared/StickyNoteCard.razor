@using NoteBuddy.Models
@using System.Globalization
@inject IJSRuntime JS
@implements IDisposable

<div class="sticky-note"
     id="@ElementId"
     style="left: @(EffectiveX.ToString(CultureInfo.InvariantCulture))px; top: @(EffectiveY.ToString(CultureInfo.InvariantCulture))px; width: @(NoteWidth.ToString(CultureInfo.InvariantCulture))px; height: @(NoteHeight.ToString(CultureInfo.InvariantCulture))px; z-index: @Note.ZIndex; background-image: url('images/sticky-notes/@(Note.Color).png'); background-size: @(NoteWidth.ToString(CultureInfo.InvariantCulture))px @(NoteHeight.ToString(CultureInfo.InvariantCulture))px;"
     @oncontextmenu="OnRightClick"
     @oncontextmenu:preventDefault="true">

    <div class="sticky-note-header" id="@HeaderId">
        <div class="sticky-note-title" style="color: @GetTitleColor();">
            @Note.Title
        </div>
        <div class="sticky-note-actions-right">
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Class="sticky-note-btn"
                           title="Edit"
                           OnClick="OnEditClicked" />
        </div>
    </div>

    <div class="sticky-note-content">
        @if (Note.Items.Count == 1)
        {
            <div class="@GetItemClass(Note.Items[0])">
                <span class="note-item-text">@Note.Items[0].Text</span>
            </div>
        }
        else if (Note.Items.Count > 1)
        {
            <ul class="note-item-list">
                @foreach (var item in Note.Items)
                {
                    <li class="note-item @(item.IsChecked ? "note-item-checked" : "")">
                        <input type="checkbox"
                               class="note-item-checkbox"
                               checked="@item.IsChecked"
                               @onchange="() => ToggleItem(item)" />
                        <span class="note-item-text">@item.Text</span>
                    </li>
                }
            </ul>
        }
    </div>

    <div class="sticky-note-footer">
        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                       Class="sticky-note-btn"
                       title="Delete"
                       OnClick="OnDeleteClicked" />
        @if (Note.DueDate.HasValue)
        {
            <span class="due-date-label" style="color: @GetDueDateColor();">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Style="@($"color: {GetDueDateColor()}; vertical-align: middle; margin-right: 2px;")" />
                @Note.DueDate.Value.ToString("M/d/yyyy h:mm tt")
            </span>
        }
        <MudIconButton id="@ResizeHandleId"
                       Icon="@Icons.Material.Filled.AspectRatio"
                       Class="sticky-note-resize-handle"
                       title="Resize" />
    </div>

    <MudMenu @ref="_contextMenu" PositionAtCursor="true" Class="sticky-note-context-menu">
        <ActivatorContent>
            <span></span>
        </ActivatorContent>
        <ChildContent>
            <MudMenuItem Icon="@Icons.Material.Filled.FlipToFront" OnClick="() => OnZOrderChanged.InvokeAsync((Note.Id, ZOrderAction.BringToFront))">Bring to Front</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.ArrowUpward" OnClick="() => OnZOrderChanged.InvokeAsync((Note.Id, ZOrderAction.BringForward))">Bring Forward</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.ArrowDownward" OnClick="() => OnZOrderChanged.InvokeAsync((Note.Id, ZOrderAction.SendBackward))">Send Backward</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.FlipToBack" OnClick="() => OnZOrderChanged.InvokeAsync((Note.Id, ZOrderAction.SendToBack))">Send to Back</MudMenuItem>
        </ChildContent>
    </MudMenu>
</div>

@code {
    /// <summary>The sticky note model to display.</summary>
    [Parameter] public StickyNote Note { get; set; } = default!;

    /// <summary>Callback invoked when the user requests to edit this note.</summary>
    [Parameter] public EventCallback<StickyNote> OnEdit { get; set; }

    /// <summary>Callback invoked when the user requests to delete this note.</summary>
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    /// <summary>Callback invoked when the note is dragged to a new position.</summary>
    [Parameter] public EventCallback<(Guid Id, double X, double Y)> OnMoved { get; set; }

    /// <summary>Callback invoked when a checklist item is toggled on or off.</summary>
    [Parameter] public EventCallback<StickyNote> OnItemToggled { get; set; }

    /// <summary>Callback invoked when the note is resized.</summary>
    [Parameter] public EventCallback<(Guid Id, double Scale)> OnResized { get; set; }

    /// <summary>Callback invoked when the user changes this note's z-order via the context menu.</summary>
    [Parameter] public EventCallback<(Guid Id, ZOrderAction Action)> OnZOrderChanged { get; set; }

    /// <summary>Optional display X override for temporary layout (e.g., filtering). When null, uses Note.PositionX.</summary>
    [Parameter] public double? DisplayX { get; set; }

    /// <summary>Optional display Y override for temporary layout (e.g., filtering). When null, uses Note.PositionY.</summary>
    [Parameter] public double? DisplayY { get; set; }

    /// <summary>The effective X position used for rendering.</summary>
    private double EffectiveX => DisplayX ?? Note.PositionX;

    /// <summary>The effective Y position used for rendering.</summary>
    private double EffectiveY => DisplayY ?? Note.PositionY;

    /// <summary>Maps sticky note color names to their corresponding title text hex colors.</summary>
    private static readonly Dictionary<string, string> TitleColors = new()
    {
        ["yellow"] = "#b8960a",
        ["blue"] = "#5a9aaa",
        ["green"] = "#2d8a2d",
        ["orange"] = "#c07a5a",
        ["pink"] = "#c060a0",
        ["purple"] = "#7a3d9a"
    };

    // Base dimensions at scale 1.0
    private const double BaseWidth = 325.0;
    private const double BaseHeight = 324.0;
    private const double MinScale = 1.0;
    private const double MaxScale = 2.0;

    /// <summary>Computed width based on the note's scale factor.</summary>
    private double NoteWidth => BaseWidth * Note.Scale;

    /// <summary>Computed height based on the note's scale factor.</summary>
    private double NoteHeight => BaseHeight * Note.Scale;

    /// <summary>Unique DOM element ID for this note's container.</summary>
    private string ElementId => $"note-{Note.Id}";

    /// <summary>Unique DOM element ID for this note's header (drag area).</summary>
    private string HeaderId => $"header-{Note.Id}";

    /// <summary>Unique DOM element ID for this note's resize handle.</summary>
    private string ResizeHandleId => $"resize-{Note.Id}";

    /// <summary>.NET object reference passed to JS for drag and resize callbacks.</summary>
    private DotNetObjectReference<StickyNoteCard>? _dotNetRef;

    /// <summary>Tracks whether JS interop has been initialized.</summary>
    private bool _jsInitialized;

    /// <summary>Reference to the MudMenu used as the right-click context menu.</summary>
    private MudMenu? _contextMenu;

    /// <summary>Returns the title text color for the current note color, defaulting to dark gray.</summary>
    private string GetTitleColor() =>
        TitleColors.GetValueOrDefault(Note.Color, "#333333");

    /// <summary>Initializes the JS drag-and-drop and resize interop after the component renders.</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !_jsInitialized)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("corkboardInterop.initDraggable", ElementId, HeaderId, _dotNetRef);
            await JS.InvokeVoidAsync("corkboardInterop.initResizable", ElementId, ResizeHandleId, _dotNetRef, BaseWidth, BaseHeight, MinScale, MaxScale);
            _jsInitialized = true;
        }
    }

    /// <summary>Called from JavaScript when the note is dragged to a new position.</summary>
    [JSInvokable]
    public async Task OnPositionChanged(double x, double y)
    {
        Note.PositionX = x;
        Note.PositionY = y;
        await OnMoved.InvokeAsync((Note.Id, x, y));
    }

    /// <summary>Called from JavaScript when the note is resized.</summary>
    [JSInvokable]
    public async Task OnScaleChanged(double scale)
    {
        // Clamp scale to valid range
        scale = Math.Max(MinScale, Math.Min(MaxScale, scale));
        Note.Scale = scale;
        await OnResized.InvokeAsync((Note.Id, scale));
        StateHasChanged();
    }

    /// <summary>Opens the context menu on right-click.</summary>
    private void OnRightClick(MouseEventArgs e)
    {
        _contextMenu?.OpenMenuAsync(e);
    }

    /// <summary>Forwards the edit request to the parent component.</summary>
    private async Task OnEditClicked()
    {
        await OnEdit.InvokeAsync(Note);
    }

    /// <summary>Forwards the delete request to the parent component.</summary>
    private async Task OnDeleteClicked()
    {
        await OnDelete.InvokeAsync(Note.Id);
    }

    /// <summary>Toggles a checklist item's checked state and notifies the parent.</summary>
    private async Task ToggleItem(NoteItem item)
    {
        item.IsChecked = !item.IsChecked;
        await OnItemToggled.InvokeAsync(Note);
        StateHasChanged();
    }

    /// <summary>Returns CSS classes for a single-item note, applying strikethrough styling when checked.</summary>
    private string GetItemClass(NoteItem item)
    {
        return item.IsChecked ? "note-item-single note-item-checked" : "note-item-single";
    }

    /// <summary>
    /// Returns the appropriate font color for the due date display.
    /// Blue when in the reminder window, red when 12+ hours overdue, dark gray otherwise.
    /// </summary>
    private string GetDueDateColor()
    {
        if (!Note.DueDate.HasValue) return "#555555";

        var now = DateTime.Now;
        var due = Note.DueDate.Value;

        // Red: 12+ hours past due
        if (now > due.AddHours(12))
            return "#d32f2f";

        // Blue: within reminder window (and reminder is set)
        if (Note.ReminderMinutesBefore.HasValue)
        {
            var reminderStart = due.AddMinutes(-Note.ReminderMinutesBefore.Value);
            if (now >= reminderStart && now <= due)
                return "#1976d2";
        }

        return "#555555";
    }

    /// <summary>Disposes the .NET object reference used for JS interop.</summary>
    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
