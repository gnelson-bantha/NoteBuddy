@using NoteBuddy.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEditMode ? "Edit Sticky Note" : "New Sticky Note")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Title"
                      Label="Title"
                      Variant="Variant.Outlined"
                      Placeholder="Enter a title..."
                      MaxLength="50"
                      Counter="50"
                      Immediate="true"
                      Required="true"
                      RequiredError="Title is required"
                      FullWidth="true"
                      Class="mb-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Choose a color:</MudText>
        <div class="color-picker-grid">
            @foreach (var color in Colors)
            {
                <div class="color-swatch @(SelectedColor == color ? "selected" : "")"
                     style="background-image: url('images/sticky-notes/@(color).png');"
                     title="@color"
                     @onclick="() => SelectedColor = color">
                </div>
            }
        </div>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">
            Items (@Items.Count / @MaxItems):
        </MudText>

        @for (int i = 0; i < Items.Count; i++)
        {
            var index = i;
            <div class="d-flex align-center gap-2 mb-2">
                <MudTextField @bind-Value="Items[index].Text"
                              Variant="Variant.Outlined"
                              Placeholder="Enter item text..."
                              MaxLength="150"
                              Counter="150"
                              Immediate="true"
                              FullWidth="true" />
                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline"
                               Color="Color.Error"
                               Size="Size.Small"
                               title="Remove item"
                               OnClick="() => RemoveItem(index)" />
            </div>
        }

        @if (Items.Count < MaxItems)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="AddItem"
                       Class="mt-1">
                Add Item
            </MudButton>
        }

        @if (!string.IsNullOrEmpty(ValidationMessage))
        {
            <MudAlert Severity="Severity.Warning" Class="mt-2">@ValidationMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        @if (IsEditMode)
        {
            <MudButton Color="Color.Error"
                       Variant="Variant.Text"
                       OnClick="DeleteNote"
                       Class="mr-auto">
                Delete
            </MudButton>
        }
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>The MudBlazor dialog instance provided via cascading parameter.</summary>
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>When set, the dialog operates in edit mode with pre-populated fields.</summary>
    [Parameter] public StickyNote? ExistingNote { get; set; }

    /// <summary>Indicates whether the dialog is editing an existing note or creating a new one.</summary>
    private bool IsEditMode => ExistingNote != null;

    /// <summary>The currently selected sticky note background color.</summary>
    private string SelectedColor { get; set; } = "yellow";

    /// <summary>The note title entered by the user.</summary>
    private string Title { get; set; } = string.Empty;

    /// <summary>The editable list of checklist items for this note.</summary>
    private List<NoteItem> Items { get; set; } = new();

    /// <summary>Validation error message displayed to the user, if any.</summary>
    private string? ValidationMessage { get; set; }

    /// <summary>Maximum number of checklist items allowed per note.</summary>
    private const int MaxItems = 6;

    /// <summary>Available sticky note color options.</summary>
    private static readonly string[] Colors = { "yellow", "blue", "green", "orange", "pink", "purple" };

    /// <summary>Populates dialog fields from the existing note in edit mode, or adds an empty item for new notes.</summary>
    protected override void OnInitialized()
    {
        if (ExistingNote != null)
        {
            // Clone items to avoid mutating the original note until save
            Title = ExistingNote.Title;
            SelectedColor = ExistingNote.Color;
            Items = ExistingNote.Items.Select(i => new NoteItem
            {
                Id = i.Id,
                Text = i.Text,
                IsChecked = i.IsChecked
            }).ToList();
        }
        else
        {
            Items.Add(new NoteItem());
        }
    }

    /// <summary>Appends a new empty checklist item if the maximum has not been reached.</summary>
    private void AddItem()
    {
        if (Items.Count < MaxItems)
        {
            Items.Add(new NoteItem());
        }
    }

    /// <summary>Removes the checklist item at the specified index.</summary>
    private void RemoveItem(int index)
    {
        if (index >= 0 && index < Items.Count)
        {
            Items.RemoveAt(index);
        }
    }

    /// <summary>Validates inputs, strips empty items, and closes the dialog returning the saved note.</summary>
    private void Save()
    {
        if (string.IsNullOrWhiteSpace(Title))
        {
            ValidationMessage = "Please enter a title.";
            return;
        }

        // Remove empty items before saving
        var validItems = Items.Where(i => !string.IsNullOrWhiteSpace(i.Text)).ToList();

        if (validItems.Count == 0)
        {
            ValidationMessage = "Please add at least one item with text.";
            return;
        }

        var note = ExistingNote ?? new StickyNote();
        note.Title = Title.Trim();
        note.Color = SelectedColor;
        note.Items = validItems;

        MudDialog.Close(DialogResult.Ok(note));
    }

    /// <summary>Cancels the dialog without saving changes.</summary>
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    /// <summary>Closes the dialog with a null result to signal that the note should be deleted.</summary>
    private void DeleteNote()
    {
        MudDialog.Close(DialogResult.Ok<StickyNote?>(null));
    }
}
