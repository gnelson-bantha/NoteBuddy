@using NoteBuddy.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEditMode ? "Edit Sticky Note" : "New Sticky Note")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Title"
                      Label="Title"
                      Variant="Variant.Outlined"
                      Placeholder="Enter a title..."
                      MaxLength="50"
                      Counter="50"
                      Immediate="true"
                      Required="true"
                      RequiredError="Title is required"
                      FullWidth="true"
                      Class="mb-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Choose a color:</MudText>
        <div class="color-picker-grid">
            @foreach (var color in Colors)
            {
                <div class="color-swatch @(SelectedColor == color ? "selected" : "")"
                     style="background-image: url('images/sticky-notes/@(color).png');"
                     title="@color"
                     @onclick="() => SelectedColor = color">
                </div>
            }
        </div>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">
            Items (@Items.Count / @MaxItems):
        </MudText>

        @for (int i = 0; i < Items.Count; i++)
        {
            var index = i;
            <div class="d-flex align-center gap-2 mb-2">
                <MudTextField @bind-Value="Items[index].Text"
                              Variant="Variant.Outlined"
                              Placeholder="Enter item text..."
                              MaxLength="150"
                              Counter="150"
                              Immediate="true"
                              FullWidth="true" />
                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline"
                               Color="Color.Error"
                               Size="Size.Small"
                               title="Remove item"
                               OnClick="() => RemoveItem(index)" />
            </div>
        }

        @if (Items.Count < MaxItems)
        {
            <MudButton StartIcon="@Icons.Material.Filled.Add"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="AddItem"
                       Class="mt-1">
                Add Item
            </MudButton>
        }

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Due Date (optional):</MudText>
        <div class="d-flex gap-2 mb-2 align-center">
            <MudDatePicker @bind-Date="DueDate"
                           Label="Date"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           DateFormat="MM/dd/yyyy"
                           Class="flex-grow-1" />
            <MudSelect @bind-Value="DueHour" Label="Hour" Variant="Variant.Outlined" Dense="true" Style="max-width: 80px;">
                @for (int h = 1; h <= 12; h++)
                {
                    var hour = h;
                    <MudSelectItem Value="@hour">@hour</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.h6" Class="align-self-center">:</MudText>
            <MudSelect @bind-Value="DueMinute" Label="Min" Variant="Variant.Outlined" Dense="true" Style="max-width: 80px;">
                @foreach (var m in new[] { 0, 15, 30, 45 })
                {
                    <MudSelectItem Value="@m">@m.ToString("D2")</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="DueAmPm" Label="AM/PM" Variant="Variant.Outlined" Dense="true" Style="max-width: 90px;">
                <MudSelectItem Value="@("AM")">AM</MudSelectItem>
                <MudSelectItem Value="@("PM")">PM</MudSelectItem>
            </MudSelect>
        </div>

        @if (DueDate.HasValue)
        {
            <div class="d-flex gap-2 mb-2">
                <MudSelect @bind-Value="SelectedReminder"
                           Label="Reminder"
                           Variant="Variant.Outlined"
                           Class="flex-grow-1">
                    <MudSelectItem Value="@((int?)null)">No Reminder</MudSelectItem>
                    <MudSelectItem Value="@((int?)15)">15 minutes before</MudSelectItem>
                    <MudSelectItem Value="@((int?)30)">30 minutes before</MudSelectItem>
                    <MudSelectItem Value="@((int?)60)">1 hour before</MudSelectItem>
                    <MudSelectItem Value="@((int?)1440)">1 day before</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Text"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearDueDate"
                           Class="align-self-center">
                    Clear
                </MudButton>
            </div>
        }

        @if (!string.IsNullOrEmpty(ValidationMessage))
        {
            <MudAlert Severity="Severity.Warning" Class="mt-2">@ValidationMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        @if (IsEditMode)
        {
            <MudButton Color="Color.Error"
                       Variant="Variant.Text"
                       OnClick="DeleteNote"
                       Class="mr-auto">
                Delete
            </MudButton>
        }
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>The MudBlazor dialog instance provided via cascading parameter.</summary>
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>When set, the dialog operates in edit mode with pre-populated fields.</summary>
    [Parameter] public StickyNote? ExistingNote { get; set; }

    /// <summary>Indicates whether the dialog is editing an existing note or creating a new one.</summary>
    private bool IsEditMode => ExistingNote != null;

    /// <summary>The currently selected sticky note background color.</summary>
    private string SelectedColor { get; set; } = "yellow";

    /// <summary>The note title entered by the user.</summary>
    private string Title { get; set; } = string.Empty;

    /// <summary>The editable list of checklist items for this note.</summary>
    private List<NoteItem> Items { get; set; } = new();

    /// <summary>Validation error message displayed to the user, if any.</summary>
    private string? ValidationMessage { get; set; }

    /// <summary>The selected due date (date portion only).</summary>
    private DateTime? DueDate { get; set; }

    /// <summary>The selected due hour (1–12).</summary>
    private int DueHour { get; set; } = 12;

    /// <summary>The selected due minute (0, 15, 30, 45).</summary>
    private int DueMinute { get; set; } = 0;

    /// <summary>The selected AM/PM value.</summary>
    private string DueAmPm { get; set; } = "PM";

    /// <summary>The selected reminder interval in minutes before the due date.</summary>
    private int? SelectedReminder { get; set; }

    /// <summary>Maximum number of checklist items allowed per note.</summary>
    private const int MaxItems = 6;

    /// <summary>Available sticky note color options.</summary>
    private static readonly string[] Colors = { "yellow", "blue", "green", "orange", "pink", "purple" };

    /// <summary>Populates dialog fields from the existing note in edit mode, or adds an empty item for new notes.</summary>
    protected override void OnInitialized()
    {
        if (ExistingNote != null)
        {
            // Clone items to avoid mutating the original note until save
            Title = ExistingNote.Title;
            SelectedColor = ExistingNote.Color;
            Items = ExistingNote.Items.Select(i => new NoteItem
            {
                Id = i.Id,
                Text = i.Text,
                IsChecked = i.IsChecked
            }).ToList();

            // Populate due date fields
            if (ExistingNote.DueDate.HasValue)
            {
                DueDate = ExistingNote.DueDate.Value.Date;
                var hour24 = ExistingNote.DueDate.Value.Hour;
                DueAmPm = hour24 >= 12 ? "PM" : "AM";
                DueHour = hour24 % 12;
                if (DueHour == 0) DueHour = 12;
                DueMinute = ExistingNote.DueDate.Value.Minute;
            }
            SelectedReminder = ExistingNote.ReminderMinutesBefore;
        }
        else
        {
            Items.Add(new NoteItem());
        }
    }

    /// <summary>Appends a new empty checklist item if the maximum has not been reached.</summary>
    private void AddItem()
    {
        if (Items.Count < MaxItems)
        {
            Items.Add(new NoteItem());
        }
    }

    /// <summary>Removes the checklist item at the specified index.</summary>
    private void RemoveItem(int index)
    {
        if (index >= 0 && index < Items.Count)
        {
            Items.RemoveAt(index);
        }
    }

    /// <summary>Validates inputs, strips empty items, and closes the dialog returning the saved note.</summary>
    private void Save()
    {
        if (string.IsNullOrWhiteSpace(Title))
        {
            ValidationMessage = "Please enter a title.";
            return;
        }

        // Remove empty items before saving
        var validItems = Items.Where(i => !string.IsNullOrWhiteSpace(i.Text)).ToList();

        if (validItems.Count == 0)
        {
            ValidationMessage = "Please add at least one item with text.";
            return;
        }

        var note = ExistingNote ?? new StickyNote();
        note.Title = Title.Trim();
        note.Color = SelectedColor;
        note.Items = validItems;

        // Combine date and time into a single DateTime
        DateTime? newDueDate = null;
        if (DueDate.HasValue)
        {
            var hour24 = DueHour % 12 + (DueAmPm == "PM" ? 12 : 0);
            newDueDate = DueDate.Value.Date.AddHours(hour24).AddMinutes(DueMinute);
        }

        // Reset reminder dismissed state if due date was moved forward
        if (newDueDate.HasValue && note.ReminderDismissedAt.HasValue && newDueDate > note.DueDate)
        {
            note.ReminderDismissed = false;
            note.ReminderDismissedAt = null;
        }

        note.DueDate = newDueDate;
        note.ReminderMinutesBefore = DueDate.HasValue ? SelectedReminder : null;

        // Clear reminder if due date was removed
        if (!note.DueDate.HasValue)
        {
            note.ReminderMinutesBefore = null;
            note.ReminderDismissed = false;
            note.ReminderDismissedAt = null;
        }

        MudDialog.Close(DialogResult.Ok(note));
    }

    /// <summary>Cancels the dialog without saving changes.</summary>
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    /// <summary>Clears the due date, time, and reminder fields.</summary>
    private void ClearDueDate()
    {
        DueDate = null;
        DueHour = 12;
        DueMinute = 0;
        DueAmPm = "PM";
        SelectedReminder = null;
    }

    /// <summary>Closes the dialog with a null result to signal that the note should be deleted.</summary>
    private void DeleteNote()
    {
        MudDialog.Close(DialogResult.Ok<StickyNote?>(null));
    }
}
